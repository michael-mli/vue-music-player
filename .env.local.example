# Local development with existing PHP server
VITE_API_BASE_URL=/api
VITE_MUSIC_BASE_URL=/data
VITE_LYRICS_BASE_URL=/data/lyrics
VITE_POSTER_BASE_URL=/data/poster
VITE_APP_TITLE=Mic's Music Player (Local)
VITE_ENABLE_MOCK_DATA=false

# Karaoke (instrumental playback + synced lyrics). See KARAOKE.md.
# Set to false to hide the feature entirely. Default: enabled.
VITE_KARAOKE_ENABLED=true
# Synced-lyrics API base (LRCLIB). Override only to use a mirror/self-host.
VITE_LRCLIB_BASE_URL=https://lrclib.net
