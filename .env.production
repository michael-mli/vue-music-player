# Production environment variables
VITE_API_BASE_URL=/api
VITE_MUSIC_BASE_URL=/data
VITE_LYRICS_BASE_URL=/data/lyrics
VITE_POSTER_BASE_URL=/data/poster
VITE_APP_TITLE=Mic的音乐播放器
VITE_ENABLE_MOCK_DATA=true
# Karaoke assets served from a writable path (the /data music mount is read-only S3).
# See KARAOKE.md. Set empty to co-locate with the music files instead.
VITE_KARAOKE_BASE_URL=/karaoke
VITE_LRCLIB_BASE_URL=https://lrclib.net
