# ── Karaoke backend (auth + admin) environment ──────────────────────────────
# Copy to .env.server on the host and fill in. NEVER commit the filled-in file.
#
# Google OAuth: create credentials at https://console.cloud.google.com/apis/credentials
#   1. Create an OAuth 2.0 Client ID (type: Web application).
#   2. Authorized JavaScript origins:  https://music.micstec.com
#   3. Authorized redirect URIs:       https://music.micstec.com/api/auth/google/callback
#   4. Put the client id + secret below.

# --- Google Sign-In ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://music.micstec.com/api/auth/google/callback

# --- Session / JWT ---
# Long random string used to sign session tokens. Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-hex-string
SESSION_TTL_HOURS=168

# --- Bootstrap admins ---
# Comma-separated Google account emails that are auto-granted the admin role on first login.
ADMIN_EMAILS=lizhenrong@gmail.com

# --- Server ---
PORT=3101
# Absolute path to the repo so the admin ingest action can run scripts/karaoke/ingest.sh
REPO_DIR=/home/mli/others/vue-music-player
# Where the user database lives (sqlite file or json — depends on chosen store)
DATA_DIR=/var/www/html/others/music/_auth
